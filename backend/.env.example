# ============================================================================
# TriMetric Configuration
# ============================================================================
# Per lo sviluppo locale con Docker, vedi STRAVA_SETUP.md

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://trimetric:trimetric@localhost:5432/trimetric

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# Application URLs
# ============================================================================
# IMPORTANTE: In Docker Compose, questi vengono sovrascritti da variabili environment
# Usa .env.local (non committare) per sovrascrivere con le tue impostazioni locali

# Frontend - dove corre l'app React
# Sviluppo locale (Vite): http://localhost:5173
# Docker (Nginx): http://localhost:8080 
# Produzione: https://app.example.com
FRONTEND_URL=http://localhost:5173

# Backend - come altri servizi possono raggiungerti
# Sviluppo locale: http://localhost:3001
# Con ngrok per Strava: https://abc123def456.ngrok-free.dev
# Produzione: https://api.example.com
BACKEND_URL=http://localhost:3001

# ============================================================================
# Strava OAuth Configuration
# ============================================================================
# Ottieni questi da https://www.strava.com/settings/oauth

# Strava Application Client ID
STRAVA_CLIENT_ID=your_strava_client_id_here

# Strava Application Client Secret (MANTIENI SEGRETO!)
STRAVA_CLIENT_SECRET=your_strava_client_secret_here

# Token per verificare le richieste della webhook da Strava
# Usa un valore casuale lungo:
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_change_this

# OAuth redirect URI (consigliato: callback backend pubblico)
# Esempio locale con ngrok: https://abc123.ngrok-free.dev/auth/strava/callback
# Se non impostato, viene costruito automaticamente da BACKEND_URL.
STRAVA_REDIRECT_URI=

# ============================================================================
# Zepp/Mi Fit Integration (Opzionale)
# ============================================================================
ZEPP_APP_TOKEN=your_zepp_app_token_here

# ============================================================================
# Server Configuration
# ============================================================================
PORT=3001
NODE_ENV=development

# ============================================================================
# Session & JWT Secrets
# ============================================================================
# IMPORTANTE: Cambia questi in produzione! Usa valori casuali lunghi.
# Genera con: openssl rand -base64 32

SESSION_SECRET=change-this-session-secret-in-production
JWT_SECRET=change-this-jwt-secret-in-production
