# Database
DATABASE_URL=postgresql://trimetric:trimetric@localhost:5432/trimetric

# Redis
REDIS_URL=redis://localhost:6379

# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token

# Zepp/Mi Fit
ZEPP_APP_TOKEN=your_zepp_app_token

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Public URL of the backend, used as the Strava webhook callback URL.
# For local development, expose the backend with ngrok or cloudflared and set this to the tunnel URL.
# Example: BACKEND_URL=https://abc123.ngrok-free.app
BACKEND_URL=https://your-public-url.example.com
SESSION_SECRET=your_session_secret_change_in_production
JWT_SECRET=your_jwt_secret_change_in_production
